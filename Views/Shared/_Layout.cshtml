<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ZNOWay</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">?? ZNOWay</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Subjects" asp-action="Index">Предмети</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tests" asp-action="Index">Тести</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Topics" asp-action="Index">Теми</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="UserResults" asp-action="Index">Мої результати</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Адмін</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">Користувачі</a></li>
                                    <li><a class="dropdown-item" asp-controller="Questions" asp-action="Index">Питання</a></li>
                                    <li><a class="dropdown-item" asp-controller="AnswerOptions" asp-action="Index">Відповіді</a></li>
                                </ul>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="navbar-text me-3 text-white-50">?? @User.Identity.Name</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Logout">Вийти</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Увійти</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Реєстрація</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <footer class="text-center text-muted mt-5 py-3 border-top">
        <small>ZNOWay © 2024</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>