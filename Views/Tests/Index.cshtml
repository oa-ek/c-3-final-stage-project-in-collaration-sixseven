@model IEnumerable<ZNOWay.Models.Test>
@{
    ViewData["Title"] = "Тести";
    ViewData["ActivePage"] = "Tests";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="page-header">
        <div style="display:flex; align-items:center; justify-content:space-between">
            <h1><i class="bi bi-journal-text me-2" style="color:var(--clr-success)"></i>Доступні тести</h1>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn-zno btn-primary-zno">
                    <i class="bi bi-plus-lg"></i> Створити тест
                </a>
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card-zno text-center" style="padding:60px">
            <i class="bi bi-search" style="font-size:3rem; color:var(--clr-muted)"></i>
            <p style="color:var(--clr-muted); margin-top:16px">Тестів поки немає. Зайдіть пізніше!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card-zno h-100">
                        <div style="display:flex; justify-content:space-between; margin-bottom:12px">
                            <span class="badge-zno badge-blue">@item.Subject?.Name</span>
                            <span class="badge-zno badge-amber"><i class="bi bi-clock me-1"></i> @item.TimeLimit хв</span>
                        </div>

                        <h3 style="font-size:1.1rem; font-weight:700; margin-bottom:15px">@item.Name</h3>

                        <div style="display:flex; gap:10px; margin-top:auto">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-zno btn-ghost-zno" style="flex:1; justify-content:center">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-zno" style="background:rgba(244,63,94,.1); color:#f87171; border:1px solid rgba(244,63,94,.3)">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }

                            <a asp-controller="TestRun" asp-action="Start" asp-route-id="@item.Id" class="btn-zno btn-success-zno" style="flex:2; justify-content:center">
                                <i class="bi bi-play-fill"></i> Почати тест
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>