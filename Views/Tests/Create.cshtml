@model ZNOWay.Models.Test
@{
    ViewData["Title"] = "Створити тест";
    Layout = "_Layout";
}

<div class="container py-5">
    <div style="max-width:700px; margin:0 auto">
        <div class="page-header">
            <h1><i class="bi bi-journal-plus me-2" style="color:var(--clr-success)"></i>Новий тест</h1>
        </div>
        <div class="card-zno">
            <form asp-action="Create">
                <div style="margin-bottom:20px">
                    <label class="text-muted small mb-2 d-block">Назва тесту</label>
                    <input asp-for="Name" class="form-control-zno" placeholder="Наприклад: Підготовка до НМТ 2026"
                           style="background: var(--clr-surface); color: white; border: 1px solid var(--clr-border); padding: 10px; width: 100%; border-radius: 8px;" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div style="margin-bottom:20px">
                    <label class="text-muted small mb-2 d-block">Предмет</label>
                    <select asp-for="SubjectId" class="form-control-zno" asp-items="ViewBag.SubjectId"
                            style="background: var(--clr-surface); color: white; border: 1px solid var(--clr-border); padding: 10px; width: 100%; border-radius: 8px;">
                    </select>
                </div>

                <div style="margin-bottom:20px">
                    <label class="text-muted small mb-2 d-block">Тип (напр. "Екзамен" або "Тренування")</label>
                    <input asp-for="Type" class="form-control-zno" placeholder="Введіть тип тесту..."
                           style="background: var(--clr-surface); color: white; border: 1px solid var(--clr-border); padding: 10px; width: 100%; border-radius: 8px;" />
                </div>

                <div style="margin-bottom:25px">
                    <label class="text-muted small mb-2 d-block">Час на проходження (хвилини)</label>
                    <input asp-for="TimeLimit" type="number" class="form-control-zno"
                           style="background: var(--clr-surface); color: white; border: 1px solid var(--clr-border); padding: 10px; width: 100%; border-radius: 8px;" />
                </div>

                <div style="display:flex; gap:10px">
                    <button type="submit" class="btn-zno btn-primary-zno">
                        <i class="bi bi-check-lg"></i> Створити тест
                    </button>
                    <a asp-action="Index" class="btn-zno btn-ghost-zno">Назад</a>
                </div>
            </form>
        </div>
    </div>
</div>