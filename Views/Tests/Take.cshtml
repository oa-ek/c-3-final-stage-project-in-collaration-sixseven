@model TakeTestViewModel
@{
    ViewData["Title"] = "Проходження тесту";
    var isExam = Model?.TestType == "Exam";
    var totalSeconds = (Model?.TimeLimitMinutes ?? 30) * 60;
    var totalQuestions = Model?.Questions?.Count ?? 10;
}

<style>
    body { background: var(--clr-bg); }

    .take-wrap {
        min-height: calc(100vh - var(--nav-h));
        display: grid;
        grid-template-columns: 1fr 320px;
        grid-template-rows: auto 1fr;
        gap: 0;
    }

    /* ─── TOP BAR ─── */
    .test-topbar {
        grid-column: 1 / -1;
        background: var(--clr-card); border-bottom: 1px solid var(--clr-border);
        padding: 0 32px; height: 64px;
        display: flex; align-items: center; gap: 20px;
    }
    .test-title { font-family: var(--font-display); font-weight: 700; font-size: 1rem; flex: 1; }
    .test-title span { color: var(--clr-muted); font-weight: 400; font-family: var(--font-body); font-size: .85rem; }

    /* Timer */
    .timer-wrap { display: flex; align-items: center; gap: 10px; }
    .timer-display {
        font-family: var(--font-display); font-size: 1.5rem; font-weight: 900;
        letter-spacing: -.02em; color: var(--clr-text); min-width: 90px; text-align: center;
        transition: color .3s;
    }
    .timer-display.warning { color: var(--clr-warn); }
    .timer-display.danger  { color: #f87171; animation: pulse .5s infinite alternate; }
    @keyframes pulse { from { opacity: 1; } to { opacity: .5; } }
    .timer-label { color: var(--clr-muted); font-size: .78rem; }

    /* Progress */
    .top-progress { flex: 0 0 220px; }
    .top-progress-label { color: var(--clr-muted); font-size: .75rem; margin-bottom: 5px; display: flex; justify-content: space-between; }

    .btn-exit {
        display: flex; align-items: center; gap: 7px;
        padding: 7px 16px; border-radius: var(--radius-sm);
        border: 1px solid var(--clr-border); background: transparent;
        color: var(--clr-muted); font-family: var(--font-body);
        font-size: .83rem; cursor: pointer; transition: all .15s;
    }
    .btn-exit:hover { border-color: #f87171; color: #f87171; }

    /* ─── QUESTION AREA ─── */
    .question-area {
        padding: 40px 40px 40px;
        display: flex; flex-direction: column;
        overflow-y: auto;
    }

    .q-num {
        font-size: .78rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
        color: var(--clr-muted); margin-bottom: 14px;
    }
    .q-text {
        font-size: 1.1rem; line-height: 1.75; font-weight: 500;
        margin-bottom: 32px; max-width: 680px;
    }

    /* Answer Options */
    .answer-list { display: flex; flex-direction: column; gap: 12px; max-width: 680px; }
    .answer-option {
        display: flex; align-items: center; gap: 16px;
        padding: 16px 20px;
        background: var(--clr-card); border: 2px solid var(--clr-border);
        border-radius: var(--radius); cursor: pointer;
        transition: all .15s; position: relative;
        user-select: none;
    }
    .answer-option:hover { border-color: rgba(79,138,255,.5); background: rgba(79,138,255,.05); }
    .answer-option.selected { border-color: var(--clr-accent); background: rgba(79,138,255,.08); }
    .answer-option.correct  { border-color: var(--clr-success); background: rgba(34,197,94,.08); pointer-events: none; }
    .answer-option.wrong    { border-color: #f87171;            background: rgba(248,113,113,.08); pointer-events: none; }
    .answer-option.disabled { pointer-events: none; opacity: .5; }

    .answer-key {
        width: 36px; height: 36px; border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        font-family: var(--font-display); font-weight: 700; font-size: .875rem;
        background: var(--clr-surface); border: 1px solid var(--clr-border);
        flex-shrink: 0; transition: all .15s;
    }
    .answer-option.selected .answer-key { background: var(--clr-accent); border-color: var(--clr-accent); color: #fff; }
    .answer-option.correct  .answer-key { background: var(--clr-success); border-color: var(--clr-success); color: #fff; }
    .answer-option.wrong    .answer-key { background: #f87171;            border-color: #f87171;            color: #fff; }

    .answer-text { flex: 1; font-size: .95rem; line-height: 1.5; }
    .answer-check { font-size: 1.2rem; }

    /* Explanation */
    .explanation-box {
        display: none;
        background: rgba(34,197,94,.06); border: 1px solid rgba(34,197,94,.25);
        border-radius: var(--radius); padding: 18px 22px; margin-top: 20px; max-width: 680px;
    }
    .explanation-box.show { display: block; }
    .explanation-box.wrong-exp {
        background: rgba(248,113,113,.06); border-color: rgba(248,113,113,.25);
    }
    .explanation-title { font-weight: 700; font-size: .875rem; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
    .explanation-box p { color: var(--clr-muted); font-size: .875rem; margin: 0; line-height: 1.7; }

    /* Navigation buttons */
    .q-nav { display: flex; gap: 12px; align-items: center; margin-top: 36px; }
    .btn-prev, .btn-next {
        display: flex; align-items: center; gap: 8px;
        padding: 11px 24px; border-radius: var(--radius-sm);
        font-family: var(--font-body); font-weight: 600; font-size: .9rem;
        cursor: pointer; border: none; transition: all .15s;
    }
    .btn-prev { background: var(--clr-card); border: 1px solid var(--clr-border); color: var(--clr-muted); }
    .btn-prev:hover { color: var(--clr-text); border-color: var(--clr-muted); }
    .btn-next { background: var(--clr-accent); color: #fff; }
    .btn-next:hover { background: #3a77f5; transform: translateX(2px); }
    .btn-next.finish { background: var(--clr-success); }
    .btn-next.finish:hover { background: #16a34a; }
    .btn-fav {
        margin-left: auto;
        background: none; border: 1px solid var(--clr-border);
        border-radius: var(--radius-sm); padding: 10px 14px;
        color: var(--clr-muted); cursor: pointer; font-size: 1rem; transition: all .15s;
    }
    .btn-fav:hover, .btn-fav.active { color: var(--clr-warn); border-color: var(--clr-warn); background: rgba(245,158,11,.08); }

    /* ─── SIDEBAR ─── */
    .test-sidebar {
        background: var(--clr-card); border-left: 1px solid var(--clr-border);
        padding: 28px 24px; overflow-y: auto;
        display: flex; flex-direction: column; gap: 24px;
    }
    .sidebar-section h4 {
        font-family: var(--font-display); font-size: .85rem; font-weight: 700;
        color: var(--clr-muted); letter-spacing: .06em; text-transform: uppercase;
        margin-bottom: 14px;
    }

    /* Question grid */
    .q-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; }
    .q-dot {
        aspect-ratio: 1; border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        font-size: .75rem; font-weight: 700; cursor: pointer;
        background: var(--clr-surface); border: 1px solid var(--clr-border);
        color: var(--clr-muted); transition: all .15s;
    }
    .q-dot:hover   { border-color: var(--clr-accent); color: var(--clr-accent); }
    .q-dot.current { background: var(--clr-accent); border-color: var(--clr-accent); color: #fff; }
    .q-dot.answered{ background: rgba(34,197,94,.15); border-color: rgba(34,197,94,.4); color: var(--clr-success); }
    .q-dot.skipped { background: rgba(245,158,11,.1); border-color: rgba(245,158,11,.3); color: var(--clr-warn); }

    /* Stats in sidebar */
    .sidebar-stat { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--clr-border); }
    .sidebar-stat:last-child { border-bottom: none; }
    .sidebar-stat-label { color: var(--clr-muted); font-size: .83rem; }
    .sidebar-stat-val { font-weight: 700; font-size: .9rem; }

    .btn-finish-main {
        width: 100%; padding: 13px;
        background: linear-gradient(135deg, var(--clr-accent), #3a6ee8);
        color: #fff; border: none; border-radius: var(--radius-sm);
        font-family: var(--font-body); font-weight: 700; font-size: .95rem;
        cursor: pointer; transition: all .2s; margin-top: auto;
        display: flex; align-items: center; justify-content: center; gap: 9px;
    }
    .btn-finish-main:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(79,138,255,.4); }

    /* ─── EXIT MODAL ─── */
    .modal-overlay {
        position: fixed; inset: 0; z-index: 2000;
        background: rgba(0,0,0,.7); backdrop-filter: blur(6px);
        display: flex; align-items: center; justify-content: center;
        opacity: 0; pointer-events: none; transition: opacity .2s;
    }
    .modal-overlay.show { opacity: 1; pointer-events: all; }
    .modal-box {
        background: var(--clr-card); border: 1px solid var(--clr-border);
        border-radius: calc(var(--radius) * 1.4); padding: 36px;
        max-width: 400px; width: 90%; text-align: center;
        transform: scale(.95); transition: transform .2s;
    }
    .modal-overlay.show .modal-box { transform: scale(1); }
    .modal-box h3 { font-family: var(--font-display); font-size: 1.3rem; margin-bottom: 10px; }
    .modal-box p  { color: var(--clr-muted); font-size: .9rem; margin-bottom: 28px; }
    .modal-actions { display: flex; gap: 12px; }
    .modal-actions button { flex: 1; padding: 11px; border-radius: var(--radius-sm); font-family: var(--font-body); font-weight: 600; font-size: .9rem; cursor: pointer; transition: all .15s; }

    @@media (max-width: 900px) {
        .take-wrap { grid-template-columns: 1fr; grid-template-rows: auto auto 1fr auto; }
        .test-sidebar { border-left: none; border-top: 1px solid var(--clr-border); padding: 20px; }
        .question-area { padding: 24px 20px; }
        .test-topbar { padding: 0 16px; }
        .top-progress { display: none; }
    }
</style>

<!-- Top Bar -->
<div class="take-wrap">
<div class="test-topbar">
    <div class="test-title">
        @(Model?.TestName ?? "Математика — Тригонометрія")
        <span>&nbsp;·&nbsp; @(isExam ? "Режим іспиту" : "Режим навчання")</span>
    </div>

    @if (isExam)
    {
        <div class="timer-wrap">
            <div>
                <div class="timer-label" style="text-align:center">Залишилось</div>
                <div class="timer-display" id="timerDisplay">30:00</div>
            </div>
        </div>
    }

    <div class="top-progress">
        <div class="top-progress-label">
            <span>Прогрес</span>
            <span id="progressLabel">0 / @totalQuestions</span>
        </div>
        <div class="progress-zno">
            <div class="progress-zno-fill" id="topProgressBar" style="width:0%"></div>
        </div>
    </div>

    <button class="btn-exit" onclick="showExitModal()">
        <i class="bi bi-x-circle"></i> Завершити
    </button>
</div>

<!-- Question Area -->
<div class="question-area" id="questionArea">

    @{
        var questions = new[] {
            ("Яке значення sin(30°)?",
             new[]{ ("A","1/2","true"), ("B","√2/2","false"), ("C","√3/2","false"), ("D","1","false") },
             "sin(30°) = 1/2 — базове значення тригонометричної функції синус від кута 30 градусів."),
            ("Чому дорівнює cos(60°)?",
             new[]{ ("A","√3/2","false"), ("B","1/2","true"), ("C","1","false"), ("D","0","false") },
             "cos(60°) = 1/2. Для запам'ятовування використовуй таблицю значень тригонометричних функцій."),
            ("Яка формула основного тригонометричного тотожності?",
             new[]{ ("A","sin²x + cos²x = 1","true"), ("B","sin²x - cos²x = 1","false"), ("C","sinx · cosx = 1","false"), ("D","sinx + cosx = 0","false") },
             "sin²x + cos²x = 1 — це основна тригонометрична тотожність, яка випливає з теореми Піфагора."),
        };
    }

    @for (int qi = 0; qi < questions.Length; qi++)
    {
        var (qText, opts, explanation) = questions[qi];
        <div class="question-slide" id="q@(qi)" style="display:@(qi == 0 ? "block" : "none")">
            <div class="q-num">Питання @(qi+1) з @totalQuestions</div>
            <div class="q-text">@qText</div>

            <div class="answer-list" id="answerList@(qi)">
                @foreach (var (key, text, isCorrect) in opts)
                {
                    <div class="answer-option"
                         onclick="selectAnswer(this, @qi, @isCorrect.ToLower())"
                         data-correct="@isCorrect.ToLower()">
                        <div class="answer-key">@key</div>
                        <div class="answer-text">@text</div>
                        <div class="answer-check"></div>
                    </div>
                }
            </div>

            <div class="explanation-box" id="exp@(qi)">
                <div class="explanation-title">
                    <i class="bi bi-lightbulb"></i> Пояснення
                </div>
                <p>@explanation</p>
            </div>

            <div class="q-nav">
                @if (qi > 0)
                {
                    <button class="btn-prev" onclick="goTo(@(qi-1))">
                        <i class="bi bi-chevron-left"></i> Назад
                    </button>
                }
                @if (qi < questions.Length - 1)
                {
                    <button class="btn-next" id="nextBtn@(qi)" onclick="goTo(@(qi+1))">
                        Далі <i class="bi bi-chevron-right"></i>
                    </button>
                }
                else
                {
                    <button class="btn-next finish" onclick="finishTest()">
                        <i class="bi bi-check2-circle"></i> Завершити тест
                    </button>
                }
                <button class="btn-fav" id="fav@(qi)" onclick="toggleFav(@qi, this)" title="Додати в обране">
                    <i class="bi bi-bookmark"></i>
                </button>
            </div>
        </div>
    }

</div>

<!-- Sidebar -->
<div class="test-sidebar">
    <div class="sidebar-section">
        <h4>Питання</h4>
        <div class="q-grid" id="qGrid">
            @for (int i = 0; i < totalQuestions; i++)
            {
                <div class="q-dot @(i == 0 ? "current" : "")" id="dot@(i)" onclick="goTo(@i)">@(i+1)</div>
            }
        </div>
    </div>

    <div class="sidebar-section">
        <h4>Статистика</h4>
        <div class="sidebar-stat">
            <span class="sidebar-stat-label">Відповіли</span>
            <span class="sidebar-stat-val" id="statAnswered">0 / @totalQuestions</span>
        </div>
        <div class="sidebar-stat">
            <span class="sidebar-stat-label">Правильно</span>
            <span class="sidebar-stat-val" style="color:var(--clr-success)" id="statCorrect">0</span>
        </div>
        <div class="sidebar-stat">
            <span class="sidebar-stat-label">Неправильно</span>
            <span class="sidebar-stat-val" style="color:#f87171" id="statWrong">0</span>
        </div>
    </div>

    <button class="btn-finish-main" onclick="finishTest()">
        <i class="bi bi-flag-fill"></i> Здати тест
    </button>
</div>
</div>

<!-- Exit Modal -->
<div class="modal-overlay" id="exitModal">
    <div class="modal-box">
        <div style="font-size:2.5rem; margin-bottom:14px">⚠️</div>
        <h3>Завершити тест?</h3>
        <p>Ти відповів на <span id="modalAnswered">0</span> з @totalQuestions питань. Незбережені відповіді буде зараховано як неправильні.</p>
        <div class="modal-actions">
            <button onclick="hideExitModal()"
                    style="background:var(--clr-surface);border:1px solid var(--clr-border);color:var(--clr-muted)">
                Продовжити
            </button>
            <button onclick="window.location.href='/Tests/Result/1'"
                    style="background:#f87171;border:none;color:#fff">
                Завершити
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
const TOTAL = @totalQuestions;
const IS_EXAM = @isExam.ToString().ToLower();
const TOTAL_SECONDS = @totalSeconds;

let current = 0;
let answered = new Array(TOTAL).fill(false);
let correct  = new Array(TOTAL).fill(null);
let favorites = new Array(TOTAL).fill(false);
let timeLeft = TOTAL_SECONDS;
let timerInterval;

// ─── TIMER ───
if (IS_EXAM) {
    timerInterval = setInterval(() => {
        timeLeft--;
        const m = Math.floor(timeLeft / 60);
        const s = timeLeft % 60;
        const disp = document.getElementById('timerDisplay');
        disp.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
        if (timeLeft <= 300) disp.classList.add('warning');
        if (timeLeft <= 60)  { disp.classList.add('danger'); disp.classList.remove('warning'); }
        if (timeLeft <= 0)   { clearInterval(timerInterval); finishTest(); }
    }, 1000);
}

// ─── SELECT ANSWER ───
function selectAnswer(el, qi, isCorrect) {
    const list = document.getElementById('answerList' + qi);
    if (list.querySelector('.selected, .correct, .wrong')) return;

    list.querySelectorAll('.answer-option').forEach(opt => opt.classList.add('disabled'));
    el.classList.remove('disabled');

    if (isCorrect) {
        el.classList.add('correct');
        el.querySelector('.answer-check').innerHTML = '<i class="bi bi-check-circle-fill" style="color:var(--clr-success)"></i>';
        correct[qi] = true;
    } else {
        el.classList.add('wrong');
        el.querySelector('.answer-check').innerHTML = '<i class="bi bi-x-circle-fill" style="color:#f87171"></i>';
        correct[qi] = false;
        // Show correct answer
        list.querySelectorAll('[data-correct="true"]').forEach(opt => {
            opt.classList.remove('disabled');
            opt.classList.add('correct');
            opt.querySelector('.answer-check').innerHTML = '<i class="bi bi-check-circle-fill" style="color:var(--clr-success)"></i>';
        });
    }

    // Show explanation
    const exp = document.getElementById('exp' + qi);
    exp.classList.add('show');
    if (!isCorrect) exp.classList.add('wrong-exp');

    if (!answered[qi]) {
        answered[qi] = true;
        document.getElementById('dot' + qi).classList.add('answered');
        updateStats();
    }
}

// ─── NAVIGATION ───
function goTo(idx) {
    if (idx < 0 || idx >= TOTAL) return;
    document.getElementById('q' + current).style.display = 'none';
    document.getElementById('dot' + current).classList.remove('current');

    current = idx;
    document.getElementById('q' + current).style.display = 'block';
    document.getElementById('dot' + current).classList.add('current');
    updateProgress();
}

function updateProgress() {
    const pct = ((current + 1) / TOTAL) * 100;
    document.getElementById('topProgressBar').style.width = pct + '%';
    document.getElementById('progressLabel').textContent = (current + 1) + ' / ' + TOTAL;
}

function updateStats() {
    const ans = answered.filter(Boolean).length;
    const cor = correct.filter(v => v === true).length;
    const wrg = correct.filter(v => v === false).length;
    document.getElementById('statAnswered').textContent = ans + ' / ' + TOTAL;
    document.getElementById('statCorrect').textContent = cor;
    document.getElementById('statWrong').textContent = wrg;
    document.getElementById('modalAnswered').textContent = ans;
}

// ─── FAVORITES ───
function toggleFav(qi, btn) {
    favorites[qi] = !favorites[qi];
    const icon = btn.querySelector('i');
    if (favorites[qi]) {
        btn.classList.add('active');
        icon.className = 'bi bi-bookmark-fill';
    } else {
        btn.classList.remove('active');
        icon.className = 'bi bi-bookmark';
    }
}

// ─── FINISH ───
function finishTest() {
    clearInterval(timerInterval);
    window.location.href = '/Tests/Result/1';
}

// ─── EXIT MODAL ───
function showExitModal() { document.getElementById('exitModal').classList.add('show'); }
function hideExitModal() { document.getElementById('exitModal').classList.remove('show'); }
document.getElementById('exitModal').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) hideExitModal();
});

// ─── KEYBOARD SHORTCUTS ───
document.addEventListener('keydown', (e) => {
    if (['1','2','3','4'].includes(e.key)) {
        const idx = parseInt(e.key) - 1;
        const opts = document.querySelectorAll('#answerList' + current + ' .answer-option');
        if (opts[idx]) opts[idx].click();
    }
    if (e.key === 'ArrowRight') goTo(current + 1);
    if (e.key === 'ArrowLeft')  goTo(current - 1);
});

// Init
updateProgress();
</script>
}
