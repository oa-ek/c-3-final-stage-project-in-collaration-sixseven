@model ZNOWay.Models.Topic
@{
    ViewData["Title"] = "Видалити тему";
    Layout = "_Layout";
}

<div class="container py-5">
    <div style="max-width:500px; margin:0 auto">
        <div class="card-zno" style="border-color:rgba(244,63,94,.3)">
            <div style="text-align:center; padding:20px 0">
                <i class="bi bi-exclamation-octagon" style="font-size:3.5rem; color:#f87171"></i>
                <h2 style="margin-top:20px; font-family:var(--font-display); font-size:1.4rem">Видалити тему?</h2>
                <p style="color:var(--clr-muted); margin-top:10px">
                    Ви впевнені, що хочете видалити тему <strong style="color:var(--clr-text)">"@Model.Name"</strong>?
                </p>
            </div>

            <form asp-action="Delete" style="display:flex; gap:10px; justify-content:center; margin-top:20px">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-zno" style="background:rgba(244,63,94,.15); color:#f87171; border:1px solid rgba(244,63,94,.3); flex:1; justify-content:center">
                    <i class="bi bi-trash"></i> Так, видалити
                </button>
                <a asp-action="Index" class="btn-zno btn-ghost-zno" style="flex:1; justify-content:center">Скасувати</a>
            </form>
        </div>
    </div>
</div>