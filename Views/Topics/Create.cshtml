@model ZNOWay.Models.Topic
@{
    ViewData["Title"] = "Додати тему";
    Layout = "_Layout";
}

<div class="container py-5">
    <div style="max-width:600px; margin:0 auto">
        <div class="page-header">
            <h1><i class="bi bi-plus-circle me-2" style="color:var(--clr-accent)"></i>Нова тема</h1>
        </div>
        <div class="card-zno">
            <form asp-action="Create">
                <div style="margin-bottom:20px">
                    <label class="text-muted small mb-2 d-block">Виберіть предмет</label>
                    <select asp-for="SubjectId" class="form-control-zno" asp-items="ViewBag.SubjectId"
                            style="background: var(--clr-surface); color: white; border: 1px solid var(--clr-border); padding: 10px; width: 100%; border-radius: 8px;"></select>
                </div>

                <div style="margin-bottom:25px">
                    <label class="text-muted small mb-2 d-block">Назва теми</label>
                    <input asp-for="Name" class="form-control-zno" placeholder="Наприклад: Тригонометрія"
                           style="background: var(--clr-surface); color: white; border: 1px solid var(--clr-border); padding: 10px; width: 100%; border-radius: 8px;" />
                    <span asp-validation-for="Name" style="color:#f87171; font-size:.8rem"></span>
                </div>

                <div style="display:flex; gap:10px">
                    <button type="submit" class="btn-zno btn-primary-zno">
                        <i class="bi bi-check-lg"></i> Зберегти
                    </button>
                    <a asp-action="Index" class="btn-zno btn-ghost-zno">Назад</a>
                </div>
            </form>
        </div>
    </div>
</div>