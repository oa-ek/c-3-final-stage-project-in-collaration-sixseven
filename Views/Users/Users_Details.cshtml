@model ZNOWay.Models.User
@{
    ViewData["Title"] = "Профіль користувача";
}

<style>
    .details-wrap { padding: 36px 0 60px; }
    .details-card {
        background: var(--clr-card);
        border: 1px solid var(--clr-border);
        border-radius: calc(var(--radius) * 1.5);
        padding: 40px 44px;
        max-width: 520px;
        position: relative; overflow: hidden;
    }
    .details-card::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 3px;
        background: linear-gradient(90deg, var(--clr-accent2), var(--clr-accent));
    }

    /* Avatar */
    .profile-avatar {
        width: 72px; height: 72px; border-radius: 50%;
        background: linear-gradient(135deg, var(--clr-accent2), var(--clr-accent));
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; font-weight: 900; color: #fff;
        margin: 0 auto 20px;
    }
    .profile-email {
        font-family: var(--font-display); font-size: 1.15rem; font-weight: 700;
        text-align: center; margin-bottom: 8px;
    }
    .profile-id {
        text-align: center; color: var(--clr-muted); font-size: .8rem; margin-bottom: 24px;
    }

    /* Info rows */
    .info-divider {
        border: none; border-top: 1px solid var(--clr-border); margin: 24px 0;
    }
    .info-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 0; border-bottom: 1px solid var(--clr-border);
    }
    .info-row:last-of-type { border-bottom: none; }
    .info-label {
        font-size: .8rem; font-weight: 600; color: var(--clr-muted);
        text-transform: uppercase; letter-spacing: .05em;
        display: flex; align-items: center; gap: 8px;
    }
    .info-value { font-weight: 500; font-size: .9rem; }

    .role-badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 12px; border-radius: 99px;
        font-size: .75rem; font-weight: 600;
    }
    .role-admin {
        background: rgba(248,113,113,.12); border: 1px solid rgba(248,113,113,.3); color: #f87171;
    }
    .role-student {
        background: rgba(79,138,255,.12); border: 1px solid rgba(79,138,255,.3); color: var(--clr-accent);
    }

    .form-actions { display: flex; gap: 12px; margin-top: 28px; }
    .btn-cancel {
        padding: 11px 24px; border-radius: var(--radius-sm);
        border: 1px solid var(--clr-border); background: var(--clr-surface);
        color: var(--clr-muted); font-family: var(--font-body); font-weight: 600;
        text-decoration: none; display: inline-flex; align-items: center; gap: 7px;
        transition: all .15s;
    }
    .btn-cancel:hover { color: var(--clr-text); border-color: var(--clr-accent); }
</style>

<div class="details-wrap">
<div class="container">

    <div class="page-header mb-4">
        <h1><i class="bi bi-person-badge me-2" style="color:var(--clr-accent)"></i>Профіль користувача</h1>
    </div>

    <div class="details-card">
        <div class="profile-avatar">@Model.Email[0].ToString().ToUpper()</div>
        <div class="profile-email">@Model.Email</div>
        <div class="profile-id">ID: #@Model.Id</div>

        <hr class="info-divider" />

        <div class="info-row">
            <span class="info-label"><i class="bi bi-envelope"></i> Email</span>
            <span class="info-value">@Model.Email</span>
        </div>

        <div class="info-row">
            <span class="info-label"><i class="bi bi-shield"></i> Роль</span>
            <span class="info-value">
                @if (Model.Role?.ToLower() == "admin")
                {
                    <span class="role-badge role-admin"><i class="bi bi-shield-fill"></i> Admin</span>
                }
                else
                {
                    <span class="role-badge role-student"><i class="bi bi-person"></i> Student</span>
                }
            </span>
        </div>

        <div class="form-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-zno d-flex align-items-center gap-2">
                <i class="bi bi-pencil"></i> Редагувати
            </a>
            <a asp-action="Index" class="btn-cancel">
                <i class="bi bi-arrow-left"></i> Назад
            </a>
        </div>
    </div>

</div>
</div>
