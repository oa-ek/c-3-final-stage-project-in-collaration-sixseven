@model ZNOWay.Models.Subject
@{
    ViewData["Title"] = "Додати предмет";
    Layout = "_Layout";
}

<div class="container py-5">
    <div style="max-width:500px; margin:0 auto">
        <div class="page-header">
            <h1><i class="bi bi-plus-circle me-2" style="color:var(--clr-accent)"></i>Додати предмет</h1>
        </div>
        <div class="card-zno">
            <form asp-action="Create">
                <div style="margin-bottom:20px">
                    <label style="display:block; margin-bottom:6px; font-size:.875rem; color:var(--clr-muted)">Назва предмету</label>
                    <input asp-for="Name" class="form-control-zno" placeholder="Наприклад: Математика" />
                    <span asp-validation-for="Name" style="color:#f87171; font-size:.8rem"></span>
                </div>
                <div style="display:flex; gap:10px">
                    <button type="submit" class="btn-zno btn-primary-zno">
                        <i class="bi bi-check-lg"></i> Зберегти
                    </button>
                    <a asp-action="Index" class="btn-zno btn-ghost-zno">Скасувати</a>
                </div>
            </form>
        </div>
    </div>
</div>