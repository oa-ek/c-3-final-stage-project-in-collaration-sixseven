@model ZNOWay.Models.Subject
@{
    ViewData["Title"] = "Видалити предмет";
}

<style>
    .delete-wrap { padding: 36px 0 60px; }
    .delete-card {
        background: var(--clr-card); border: 1px solid rgba(248,113,113,.3);
        border-radius: calc(var(--radius) * 1.5); padding: 40px 44px;
        max-width: 460px; position: relative; overflow: hidden; text-align: center;
    }
    .delete-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
        background: linear-gradient(90deg, #f87171, #ef4444);
    }
    .delete-icon {
        width: 64px; height: 64px; border-radius: 50%;
        background: rgba(248,113,113,.12); border: 1px solid rgba(248,113,113,.3);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; color: #f87171; margin: 0 auto 20px;
    }
    .delete-card h2 { font-family: var(--font-display); font-size: 1.3rem; margin-bottom: 10px; }
    .delete-card p { color: var(--clr-muted); font-size: .9rem; margin-bottom: 24px; }
    .subject-chip {
        display: inline-flex; align-items: center; gap: 10px;
        background: var(--clr-surface); border: 1px solid var(--clr-border);
        border-radius: var(--radius-sm); padding: 10px 18px; margin-bottom: 32px;
        font-weight: 600;
    }
    .form-actions { display: flex; gap: 12px; justify-content: center; }
    .btn-danger-zno {
        padding: 11px 28px; border-radius: var(--radius-sm);
        background: #ef4444; border: none; color: #fff;
        font-family: var(--font-body); font-weight: 700; font-size: .95rem;
        cursor: pointer; display: inline-flex; align-items: center; gap: 8px; transition: all .2s;
    }
    .btn-danger-zno:hover { background: #dc2626; transform: translateY(-1px); }
    .btn-cancel {
        padding: 11px 24px; border-radius: var(--radius-sm);
        border: 1px solid var(--clr-border); background: var(--clr-surface);
        color: var(--clr-muted); font-family: var(--font-body); font-weight: 600;
        text-decoration: none; display: inline-flex; align-items: center; gap: 7px; transition: all .15s;
    }
    .btn-cancel:hover { color: var(--clr-text); border-color: var(--clr-accent); }
</style>

<div class="delete-wrap">
<div class="container d-flex justify-content-center">
    <div class="delete-card">
        <div class="delete-icon"><i class="bi bi-book"></i></div>
        <h2>Видалити предмет?</h2>
        <p>Всі пов'язані теми та тести також можуть бути видалені. Цю дію неможливо скасувати.</p>
        <div class="subject-chip">
            <i class="bi bi-mortarboard" style="color:var(--clr-accent)"></i>
            @Model.Name
        </div>
        <form asp-action="Delete">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="form-actions">
                <button type="submit" class="btn-danger-zno">
                    <i class="bi bi-trash"></i> Видалити
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <i class="bi bi-arrow-left"></i> Скасувати
                </a>
            </div>
        </form>
    </div>
</div>
</div>
