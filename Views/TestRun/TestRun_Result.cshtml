@model ZNOWay.ViewModels.ResultViewModel
@{
    ViewData["Title"] = "Результат";
    Layout = "_Layout";
    var nmtScore = (int)(100 + Model.Percentage);
    var grade = Model.Percentage >= 75 ? "excellent" : Model.Percentage >= 50 ? "good" : "poor";
    var gradeText = grade == "excellent" ? "Відмінний результат!" : grade == "good" ? "Непоганий результат!" : "Варто ще попрактикуватись!";
    var gradeIcon = grade == "excellent" ? "bi-trophy-fill" : grade == "good" ? "bi-star-half" : "bi-arrow-repeat";
    var gradeColor = grade == "excellent" ? "#27ae60" : grade == "good" ? "#f59e0b" : "#f43f5e";
}

@section Styles {
<style>
    .result-wrap {
        min-height: calc(100vh - 140px);
        display: flex; align-items: center; justify-content: center;
        padding: 48px 20px;
    }
    .result-card {
        background: #fff; border: 1px solid #e2e8f0;
        border-radius: 16px; width: 100%; max-width: 560px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,.08);
        animation: fadeUp .5s ease both;
    }
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .result-header {
        padding: 36px 40px 28px; text-align: center;
        border-bottom: 1px solid #e2e8f0;
        background: linear-gradient(135deg, rgba(58,123,213,.04), transparent);
    }
    .result-test-name {
        font-size: .8rem; font-weight: 600; letter-spacing: .08em;
        text-transform: uppercase; color: #64748b; margin-bottom: 20px;
    }
    .donut-wrap { position: relative; width: 160px; height: 160px; margin: 0 auto 20px; }
    .donut-svg { width: 100%; height: 100%; transform: rotate(-90deg); }
    .donut-bg { fill: none; stroke: #e2e8f0; stroke-width: 10; }
    .donut-fill {
        fill: none; stroke-width: 10; stroke-linecap: round;
        stroke-dasharray: 408; stroke-dashoffset: 408;
        animation: donutFill 1.2s ease .3s forwards;
    }
    @@keyframes donutFill {
        to { stroke-dashoffset: @((int)(408 - 408 * Model.Percentage / 100)); }
    }
    .donut-center {
        position: absolute; inset: 0;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
    .donut-pct { font-size: 2rem; font-weight: 900; color: #1e293b; line-height: 1; }
    .donut-label { font-size: .7rem; color: #64748b; margin-top: 4px; }
    .grade-badge {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 8px 20px; border-radius: 99px;
        font-weight: 700; font-size: .875rem; border: 1px solid;
    }
    .result-stats {
        display: grid; grid-template-columns: repeat(3, 1fr);
        border-bottom: 1px solid #e2e8f0;
    }
    .stat-cell {
        padding: 24px 16px; text-align: center;
        border-right: 1px solid #e2e8f0;
    }
    .stat-cell:last-child { border-right: none; }
    .stat-num { font-size: 1.5rem; font-weight: 900; color: #1e293b; line-height: 1; margin-bottom: 6px; }
    .stat-lbl { font-size: .75rem; color: #64748b; }
    .nmt-section { padding: 24px 40px; border-bottom: 1px solid #e2e8f0; }
    .nmt-label {
        font-size: .75rem; font-weight: 700; letter-spacing: .08em;
        text-transform: uppercase; color: #64748b; margin-bottom: 14px;
        display: flex; align-items: center; gap: 6px;
    }
    .nmt-bar-wrap {
        height: 36px; background: #f8fafc; border: 1px solid #e2e8f0;
        border-radius: 8px; overflow: hidden; position: relative;
    }
    .nmt-bar-fill {
        position: absolute; left: 0; top: 0; bottom: 0;
        background: linear-gradient(90deg, #3a7bd5, #27ae60);
        border-radius: 8px; width: 0;
        animation: nmtFill 1.2s ease .5s forwards;
        display: flex; align-items: center; justify-content: flex-end; padding-right: 10px;
    }
    @@keyframes nmtFill {
        to { width: @(Model.Percentage)%; }
    }
    .nmt-score-label { font-size: .75rem; font-weight: 900; color: #fff; white-space: nowrap; }
    .nmt-endpoints {
        display: flex; justify-content: space-between;
        margin-top: 6px; font-size: .72rem; color: #64748b;
    }
    .nmt-score-big { text-align: center; margin-top: 12px; font-weight: 700; color: #1e293b; }
    .nmt-score-big span { color: #3a7bd5; font-size: 1.1rem; font-weight: 900; }
    .result-actions {
        padding: 24px 40px; display: flex; gap: 12px; flex-wrap: wrap;
    }
    .btn-result {
        flex: 1; padding: 11px; border-radius: 8px;
        font-family: inherit; font-weight: 600; font-size: .9rem;
        cursor: pointer; transition: all .15s; text-decoration: none;
        display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .btn-result.secondary {
        background: #f8fafc; border: 1px solid #e2e8f0; color: #64748b;
    }
    .btn-result.secondary:hover { color: #1e293b; border-color: #94a3b8; }
    .btn-result.primary {
        background: #3a7bd5; border: none; color: #fff;
    }
    .btn-result.primary:hover { background: #2358a8; }
    @@media (max-width: 480px) {
        .result-header, .nmt-section, .result-actions { padding-left: 20px; padding-right: 20px; }
    }
</style>
}

<div class="result-wrap">
    <div class="result-card">

        <div class="result-header">
            <div class="result-test-name">@Model.TestName</div>
            <div class="donut-wrap">
                <svg class="donut-svg" viewBox="0 0 140 140">
                    <circle class="donut-bg" cx="70" cy="70" r="65"/>
                    <circle class="donut-fill" cx="70" cy="70" r="65"
                            style="stroke:@gradeColor"/>
                </svg>
                <div class="donut-center">
                    <div class="donut-pct">@Model.Percentage%</div>
                    <div class="donut-label">результат</div>
                </div>
            </div>
            <div class="grade-badge"
                 style="color:@gradeColor; border-color:@gradeColor;">
                <i class="bi @gradeIcon"></i> @gradeText
            </div>
        </div>

        <div class="result-stats">
            <div class="stat-cell">
                <div class="stat-num" style="color:#27ae60">@Model.Score</div>
                <div class="stat-lbl">правильних</div>
            </div>
            <div class="stat-cell">
                <div class="stat-num" style="color:#f43f5e">@(Model.TotalQuestions - Model.Score)</div>
                <div class="stat-lbl">помилок</div>
            </div>
            <div class="stat-cell">
                <div class="stat-num">@Model.TotalQuestions</div>
                <div class="stat-lbl">всього</div>
            </div>
        </div>

        <div class="nmt-section">
            <div class="nmt-label">
                <i class="bi bi-bar-chart-line"></i> Прогноз балу НМТ
            </div>
            <div class="nmt-bar-wrap">
                <div class="nmt-bar-fill">
                    <span class="nmt-score-label">~@nmtScore</span>
                </div>
            </div>
            <div class="nmt-endpoints"><span>100</span><span>200</span></div>
            <div class="nmt-score-big">
                Орієнтовний бал: <span>~@nmtScore / 200</span>
            </div>
        </div>

        <div class="result-actions">
            <a asp-controller="Tests" asp-action="Index" class="btn-result secondary">
                <i class="bi bi-journal-text"></i> Тести
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn-result primary">
                <i class="bi bi-house"></i> Головна
            </a>
        </div>

    </div>
</div>
