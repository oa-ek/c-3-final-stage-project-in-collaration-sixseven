@model ZNOWay.ViewModels.TestRunViewModel
@{
    ViewData["Title"] = "Start";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">@Model.TestName</h3>
            </div>
            <div class="card-body">
                <p><strong>Предмет:</strong> @Model.SubjectName</p>
                <p><strong>Кількість питань:</strong> @Model.TotalQuestions</p>
                <p>
                    <strong>Час:</strong>
                    @(Model.TimeLimit.HasValue ? $"{Model.TimeLimit} хвилин" : "Без обмежень")
                </p>
            </div>
            <div class="card-footer">
                <a asp-action="Question"
                   asp-route-testId="@Model.TestId"
                   asp-route-questionIndex="0"
                   class="btn btn-success btn-lg w-100">
                    Почати тест
                </a>
            </div>
        </div>
    </div>
</div>