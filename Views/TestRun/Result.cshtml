@model ZNOWay.ViewModels.ResultViewModel
@{
    ViewData["Title"] = "Результат";
    Layout = "_Layout";

    // NMT score scale: 100–200 based on percentage
    var nmtScore = (int)(100 + Model.Percentage);
    var grade = Model.Percentage >= 75 ? "excellent" : Model.Percentage >= 50 ? "good" : "poor";
    var gradeText = grade == "excellent" ? "Відмінний результат!" : grade == "good" ? "Непоганий результат!" : "Варто ще попрактикуватись!";
    var gradeIcon = grade == "excellent" ? "bi-trophy-fill" : grade == "good" ? "bi-star-half" : "bi-arrow-repeat";
    var gradeColor = grade == "excellent" ? "var(--clr-success)" : grade == "good" ? "var(--clr-warn)" : "#f43f5e";
}

@section Styles {
<style>
    .result-wrap {
        min-height: calc(100vh - var(--nav-h));
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 20px;
        background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(79,138,255,.07), transparent);
    }

    .result-card {
        background: var(--clr-card);
        border: 1px solid var(--clr-border);
        border-radius: calc(var(--radius) * 1.3);
        width: 100%;
        max-width: 560px;
        overflow: hidden;
        animation: fadeUp .5s ease both;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── HEADER ── */
    .result-header {
        padding: 36px 40px 28px;
        text-align: center;
        border-bottom: 1px solid var(--clr-border);
        position: relative;
        overflow: hidden;
    }
    .result-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(79,138,255,.08), transparent);
        pointer-events: none;
    }

    .result-test-name {
        font-size: .8rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--clr-muted);
        margin-bottom: 20px;
    }

    /* ── DONUT ── */
    .donut-wrap {
        position: relative;
        width: 160px;
        height: 160px;
        margin: 0 auto 20px;
    }
    .donut-svg { width: 100%; height: 100%; transform: rotate(-90deg); }
    .donut-bg   { fill: none; stroke: var(--clr-border); stroke-width: 10; }
    .donut-fill {
        fill: none;
        stroke-width: 10;
        stroke-linecap: round;
        stroke-dasharray: 408;
        stroke-dashoffset: 408;
        animation: donutFill 1.2s ease .3s forwards;
    }
    @keyframes donutFill {
        to { stroke-dashoffset: @((int)(408 - 408 * Model.Percentage / 100)); }
    }
    .donut-center {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    .donut-pct {
        font-family: var(--font-display);
        font-size: 2rem;
        font-weight: 900;
        color: var(--clr-text);
        line-height: 1;
    }
    .donut-label {
        font-size: .7rem;
        color: var(--clr-muted);
        margin-top: 4px;
    }

    .grade-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 20px;
        border-radius: 99px;
        font-weight: 700;
        font-size: .875rem;
        border: 1px solid;
    }

    /* ── STATS ── */
    .result-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-bottom: 1px solid var(--clr-border);
    }
    .stat-cell {
        padding: 24px 16px;
        text-align: center;
        border-right: 1px solid var(--clr-border);
    }
    .stat-cell:last-child { border-right: none; }
    .stat-num {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--clr-text);
        line-height: 1;
        margin-bottom: 6px;
    }
    .stat-lbl { font-size: .75rem; color: var(--clr-muted); }

    /* ── NMT SCALE ── */
    .nmt-section {
        padding: 24px 40px;
        border-bottom: 1px solid var(--clr-border);
    }
    .nmt-label {
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--clr-muted);
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .nmt-bar-wrap {
        position: relative;
        height: 36px;
        background: var(--clr-surface);
        border: 1px solid var(--clr-border);
        border-radius: var(--radius-sm);
        overflow: hidden;
    }
    .nmt-bar-fill {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        background: linear-gradient(90deg, var(--clr-accent), var(--clr-accent2));
        border-radius: var(--radius-sm);
        width: 0;
        animation: nmtFill 1.2s ease .5s forwards;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding-right: 10px;
    }
    @keyframes nmtFill {
        to { width: @(Model.Percentage)%; }
    }
    .nmt-score-label {
        font-family: var(--font-display);
        font-size: .75rem;
        font-weight: 900;
        color: #fff;
        white-space: nowrap;
    }
    .nmt-endpoints {
        display: flex;
        justify-content: space-between;
        margin-top: 6px;
        font-size: .72rem;
        color: var(--clr-muted);
    }
    .nmt-score-big {
        text-align: center;
        margin-top: 12px;
    }
    .nmt-score-big span {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 900;
        background: linear-gradient(135deg, var(--clr-accent), var(--clr-accent2));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* ── ACTIONS ── */
    .result-actions {
        padding: 24px 40px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }
    .result-actions .btn-zno { flex: 1; justify-content: center; }

    @@media (max-width: 480px) {
        .result-header, .nmt-section, .result-actions { padding-left: 20px; padding-right: 20px; }
        .result-stats { grid-template-columns: repeat(3,1fr); }
        .stat-num { font-size: 1.2rem; }
    }
</style>
}

<div class="result-wrap">
    <div class="result-card">

        <!-- HEADER -->
        <div class="result-header">
            <div class="result-test-name">@Model.TestName</div>

            <div class="donut-wrap">
                <svg class="donut-svg" viewBox="0 0 140 140">
                    <circle class="donut-bg" cx="70" cy="70" r="65"/>
                    <circle class="donut-fill" cx="70" cy="70" r="65"
                            style="stroke:@gradeColor"/>
                </svg>
                <div class="donut-center">
                    <div class="donut-pct">@Model.Percentage%</div>
                    <div class="donut-label">результат</div>
                </div>
            </div>

            <div class="grade-badge"
                 style="color:@gradeColor; border-color:@gradeColor; background:@gradeColor + '1a'">
                <i class="bi @gradeIcon"></i> @gradeText
            </div>
        </div>

        <!-- STATS -->
        <div class="result-stats">
            <div class="stat-cell">
                <div class="stat-num" style="color:var(--clr-success)">@Model.Score</div>
                <div class="stat-lbl">правильних</div>
            </div>
            <div class="stat-cell">
                <div class="stat-num" style="color:#f43f5e">@(Model.TotalQuestions - Model.Score)</div>
                <div class="stat-lbl">помилок</div>
            </div>
            <div class="stat-cell">
                <div class="stat-num">@Model.TotalQuestions</div>
                <div class="stat-lbl">всього</div>
            </div>
        </div>

        <!-- NMT SCALE -->
        <div class="nmt-section">
            <div class="nmt-label">
                <i class="bi bi-bar-chart-line"></i> Прогноз балу НМТ
            </div>
            <div class="nmt-bar-wrap">
                <div class="nmt-bar-fill">
                    <span class="nmt-score-label">~@nmtScore</span>
                </div>
            </div>
            <div class="nmt-endpoints">
                <span>100</span>
                <span>200</span>
            </div>
            <div class="nmt-score-big">
                Орієнтовний бал: <span>~@nmtScore / 200</span>
            </div>
        </div>

        <!-- ACTIONS -->
        <div class="result-actions">
            <a asp-controller="Tests" asp-action="Index" class="btn-zno btn-ghost-zno">
                <i class="bi bi-journal-text"></i> Тести
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn-zno btn-primary-zno">
                <i class="bi bi-house"></i> Головна
            </a>
        </div>

    </div>
</div>
