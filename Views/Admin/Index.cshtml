@{
    ViewData["Title"] = "Адміністративна панель";
    ViewData["ActivePage"] = "Admin";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="page-header">
        <h1><i class="bi bi-shield-check me-2" style="color:var(--clr-accent2)"></i>Адміністративна панель</h1>
        <p style="color:var(--clr-muted); margin-top:8px">Управління всім контентом платформи</p>
    </div>

    <!-- Статистика -->
    <div class="row g-3 mb-5">
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card-zno text-center">
                <div style="font-size:1.75rem; font-weight:700; color:var(--clr-accent)">@ViewBag.UsersCount</div>
                <div style="color:var(--clr-muted); font-size:.8rem; margin-top:4px">Користувачів</div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card-zno text-center">
                <div style="font-size:1.75rem; font-weight:700; color:var(--clr-success)">@ViewBag.SubjectsCount</div>
                <div style="color:var(--clr-muted); font-size:.8rem; margin-top:4px">Предметів</div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card-zno text-center">
                <div style="font-size:1.75rem; font-weight:700; color:var(--clr-accent2)">@ViewBag.TestsCount</div>
                <div style="color:var(--clr-muted); font-size:.8rem; margin-top:4px">Тестів</div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card-zno text-center">
                <div style="font-size:1.75rem; font-weight:700; color:var(--clr-warn)">@ViewBag.QuestionsCount</div>
                <div style="color:var(--clr-muted); font-size:.8rem; margin-top:4px">Питань</div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="card-zno text-center">
                <div style="font-size:1.75rem; font-weight:700; color:#f87171">@ViewBag.ResultsCount</div>
                <div style="color:var(--clr-muted); font-size:.8rem; margin-top:4px">Результатів</div>
            </div>
        </div>
    </div>

    <!-- CRUD секції -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card-zno h-100">
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px">
                    <i class="bi bi-book" style="color:var(--clr-accent); font-size:1.3rem"></i>
                    <span style="font-weight:700; font-size:1rem">Предмети та Теми</span>
                </div>
                <div style="display:flex; flex-direction:column; gap:10px">
                    <a asp-controller="Subjects" asp-action="Index"
                       style="display:flex; align-items:center; gap:8px; padding:10px 14px; background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-sm); color:var(--clr-text); text-decoration:none; transition:all .2s ease">
                        <i class="bi bi-collection"></i> Управління предметами
                    </a>
                    <a asp-controller="Topics" asp-action="Index"
                       style="display:flex; align-items:center; gap:8px; padding:10px 14px; background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-sm); color:var(--clr-text); text-decoration:none; transition:all .2s ease">
                        <i class="bi bi-tag"></i> Управління темами
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-zno h-100">
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px">
                    <i class="bi bi-journal-text" style="color:var(--clr-success); font-size:1.3rem"></i>
                    <span style="font-weight:700; font-size:1rem">Тести та Питання</span>
                </div>
                <div style="display:flex; flex-direction:column; gap:10px">
                    <a asp-controller="Tests" asp-action="Index"
                       style="display:flex; align-items:center; gap:8px; padding:10px 14px; background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-sm); color:var(--clr-text); text-decoration:none; transition:all .2s ease">
                        <i class="bi bi-file-earmark-text"></i> Управління тестами
                    </a>
                    <a asp-controller="Questions" asp-action="Index"
                       style="display:flex; align-items:center; gap:8px; padding:10px 14px; background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-sm); color:var(--clr-text); text-decoration:none; transition:all .2s ease">
                        <i class="bi bi-question-circle"></i> Управління питаннями
                    </a>
                    <a asp-controller="AnswerOptions" asp-action="Index"
                       style="display:flex; align-items:center; gap:8px; padding:10px 14px; background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-sm); color:var(--clr-text); text-decoration:none; transition:all .2s ease">
                        <i class="bi bi-list-check"></i> Варіанти відповідей
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-zno h-100">
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px">
                    <i class="bi bi-people" style="color:#f87171; font-size:1.3rem"></i>
                    <span style="font-weight:700; font-size:1rem">Користувачі та Результати</span>
                </div>
                <div style="display:flex; flex-direction:column; gap:10px">
                    <a asp-controller="Users" asp-action="Index"
                       style="display:flex; align-items:center; gap:8px; padding:10px 14px; background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-sm); color:var(--clr-text); text-decoration:none; transition:all .2s ease">
                        <i class="bi bi-person-gear"></i> Управління користувачами
                    </a>
                    <a asp-controller="UserResults" asp-action="Index"
                       style="display:flex; align-items:center; gap:8px; padding:10px 14px; background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius-sm); color:var(--clr-text); text-decoration:none; transition:all .2s ease">
                        <i class="bi bi-bar-chart-line"></i> Результати тестів
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>