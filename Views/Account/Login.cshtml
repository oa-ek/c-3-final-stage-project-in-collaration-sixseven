@model ZNOWay.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Вхід";
}

<style>
    .auth-wrap {
        min-height: calc(100vh - 140px);
        display: flex; align-items: center; justify-content: center;
        padding: 48px 16px;
    }
    .auth-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 48px 44px;
        width: 100%; max-width: 440px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0,0,0,.08);
    }
    .auth-card::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 3px;
        background: linear-gradient(90deg, #3a7bd5, #27ae60);
    }
    .auth-logo {
        font-weight: 900; font-size: 1.5rem;
        background: linear-gradient(135deg, #3a7bd5, #27ae60);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-align: center; margin-bottom: 8px;
    }
    .auth-card h2 {
        font-weight: 700; font-size: 1.4rem;
        text-align: center; margin-bottom: 6px; color: #1e293b;
    }
    .auth-sub {
        color: #64748b; text-align: center;
        font-size: .875rem; margin-bottom: 36px;
    }
    .form-group { margin-bottom: 20px; }
    .form-label-zno {
        display: block; font-size: .83rem; font-weight: 600;
        color: #64748b; margin-bottom: 8px; letter-spacing: .02em;
    }
    .input-wrap { position: relative; }
    .input-icon {
        position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
        color: #94a3b8; pointer-events: none; font-size: 1rem;
    }
    .form-control-zno {
        width: 100%;
        padding: 11px 16px 11px 38px;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        font-size: .925rem;
        color: #1e293b;
        background: #f8fafc;
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        font-family: inherit;
    }
    .form-control-zno:focus {
        border-color: #3a7bd5;
        box-shadow: 0 0 0 3px rgba(58,123,213,.12);
        background: #fff;
    }
    .toggle-pw {
        position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
        background: none; border: none; color: #94a3b8; cursor: pointer;
        font-size: 1rem; padding: 4px; transition: color .15s;
    }
    .toggle-pw:hover { color: #1e293b; }
    .form-error {
        color: #f87171; font-size: .78rem; margin-top: 5px;
        display: flex; align-items: center; gap: 5px;
    }
    .alert-error-zno {
        background: rgba(248,113,113,.1);
        border: 1px solid rgba(248,113,113,.3);
        border-radius: 8px;
        padding: 12px 16px;
        color: #dc2626;
        font-size: .875rem;
        margin-bottom: 20px;
    }
    .btn-submit {
        width: 100%; padding: 13px;
        background: linear-gradient(135deg, #3a7bd5, #2358a8);
        color: #fff; border: none; border-radius: 8px;
        font-weight: 700; font-size: 1rem;
        cursor: pointer; transition: all .2s; margin-top: 8px;
        display: flex; align-items: center; justify-content: center; gap: 9px;
        font-family: inherit;
    }
    .btn-submit:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 24px rgba(58,123,213,.4);
    }
    .remember-row {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 24px;
    }
    .remember-check {
        display: flex; align-items: center; gap: 8px; cursor: pointer;
    }
    .remember-check input[type=checkbox] {
        accent-color: #3a7bd5; width: 15px; height: 15px; cursor: pointer;
    }
    .remember-check span { color: #64748b; font-size: .85rem; }
    .forgot-link {
        color: #3a7bd5; font-size: .85rem; text-decoration: none;
    }
    .forgot-link:hover { text-decoration: underline; }
    .auth-footer {
        text-align: center; color: #64748b;
        font-size: .875rem; margin-top: 28px;
    }
    .auth-footer a {
        color: #3a7bd5; text-decoration: none; font-weight: 600;
    }
    .auth-footer a:hover { text-decoration: underline; }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">ZNOway</div>
        <h2>Вхід в акаунт</h2>
        <p class="auth-sub">Раді бачити тебе знову 👋</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error-zno">
                <i class="bi bi-exclamation-circle me-2"></i>
                Невірний email або пароль. Спробуй ще раз.
            </div>
        }

        <form asp-action="Login" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label-zno" asp-for="Email">Email</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Email" class="form-control-zno" type="email"
                           placeholder="your@email.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="form-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label-zno" asp-for="Password">Пароль</label>
                <div class="input-wrap">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Password" class="form-control-zno" type="password"
                           id="passwordInput" placeholder="••••••••"
                           autocomplete="current-password" />
                    <button type="button" class="toggle-pw" onclick="togglePw()">
                        <i class="bi bi-eye" id="pwIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="form-error"></span>
            </div>

            <div class="remember-row">
                <label class="remember-check">
                    <input type="checkbox" name="rememberMe" />
                    <span>Запам'ятати мене</span>
                </label>
                <a href="#" class="forgot-link">Забув пароль?</a>
            </div>

            <button type="submit" class="btn-submit">
                <i class="bi bi-box-arrow-in-right"></i> Увійти
            </button>
        </form>

        <div class="auth-footer">
            Ще немає акаунту?
            <a asp-controller="Account" asp-action="Register">Зареєструватись</a>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function togglePw() {
        const inp = document.getElementById('passwordInput');
        const ico = document.getElementById('pwIcon');
        if (inp.type === 'password') {
            inp.type = 'text';
            ico.className = 'bi bi-eye-slash';
        } else {
            inp.type = 'password';
            ico.className = 'bi bi-eye';
        }
    }
</script>
}
