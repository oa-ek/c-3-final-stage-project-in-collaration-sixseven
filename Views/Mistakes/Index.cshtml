@model MistakesViewModel
@{
    ViewData["Title"] = "Робота над помилками";
    ViewData["ActivePage"] = "Mistakes";
}

<style>
    .mistakes-wrap { padding: 36px 0 60px; }
    .mistake-card {
        background: var(--clr-card); border: 1px solid var(--clr-border);
        border-radius: var(--radius); padding: 24px; margin-bottom: 16px;
        transition: all .2s;
    }
    .mistake-card:hover { border-color: rgba(248,113,113,.4); }
    .mistake-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 16px; }
    .mistake-q { font-weight: 600; font-size: .95rem; line-height: 1.55; flex: 1; }
    .mistake-subject { flex-shrink: 0; }
    .answer-row { display: flex; flex-direction: column; gap: 8px; }
    .ans-chip {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 8px 14px; border-radius: var(--radius-sm); font-size: .85rem;
    }
    .ans-chip.user-wrong  { background: rgba(248,113,113,.1); border: 1px solid rgba(248,113,113,.3); color: #f87171; }
    .ans-chip.true-answer { background: rgba(34,197,94,.1);  border: 1px solid rgba(34,197,94,.3);  color: var(--clr-success); }
    .explanation-text {
        background: rgba(79,138,255,.06); border: 1px solid rgba(79,138,255,.2);
        border-radius: var(--radius-sm); padding: 12px 16px;
        font-size: .85rem; color: var(--clr-muted); line-height: 1.7;
        margin-top: 14px; display: none;
    }
    .explanation-text.open { display: block; }
    .mistake-footer {
        display: flex; align-items: center; gap: 10px;
        margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--clr-border);
    }
    .btn-explain {
        background: none; border: 1px solid var(--clr-border); border-radius: var(--radius-sm);
        padding: 6px 14px; color: var(--clr-muted); font-size: .8rem; cursor: pointer;
        transition: all .15s; font-family: var(--font-body);
        display: flex; align-items: center; gap: 6px;
    }
    .btn-explain:hover { border-color: var(--clr-accent); color: var(--clr-accent); }
    .btn-resolve {
        background: rgba(34,197,94,.1); border: 1px solid rgba(34,197,94,.3);
        border-radius: var(--radius-sm); padding: 6px 14px;
        color: var(--clr-success); font-size: .8rem; cursor: pointer;
        font-family: var(--font-body); display: flex; align-items: center; gap: 6px;
        transition: all .15s;
    }
    .btn-resolve:hover { background: rgba(34,197,94,.2); }
    .mistakes-empty {
        text-align: center; padding: 80px 20px;
        color: var(--clr-muted);
    }
    .mistakes-empty .icon { font-size: 4rem; margin-bottom: 16px; }
    .mistakes-empty h3 { font-family: var(--font-display); font-size: 1.2rem; margin-bottom: 8px; color: var(--clr-text); }
</style>

<div class="mistakes-wrap">
<div class="container">

    <div class="page-header">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px">
            <div>
                <h1><i class="bi bi-x-circle me-2" style="color:#f87171"></i>Робота над помилками</h1>
                <p style="color:var(--clr-muted);margin-top:6px">Повтори питання де ти помилився</p>
            </div>
            <a href="/Tests/Practice?mode=mistakes" class="btn-zno btn-primary-zno">
                <i class="bi bi-play-fill"></i> Практикувати всі
            </a>
        </div>
    </div>

    <!-- Filter -->
    <div style="display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap">
        <select class="filter-select" style="max-width:200px; background:var(--clr-card);border:1px solid var(--clr-border);border-radius:var(--radius-sm);color:var(--clr-text);padding:9px 32px 9px 14px;font-family:var(--font-body)">
            <option>Всі предмети</option>
            <option>📐 Математика</option>
            <option>📝 Українська</option>
            <option>🏛 Історія</option>
        </select>
        <div style="margin-left:auto;color:var(--clr-muted);font-size:.875rem;display:flex;align-items:center">
            Всього помилок: <strong style="color:var(--clr-text);margin-left:6px">64</strong>
        </div>
    </div>

    @{
        var mistakes = new[] {
            ("📐", "Математика", "badge-blue",
             "Чому дорівнює cos(60°)?",
             "Твоя відповідь: √3/2",
             "Правильна: 1/2",
             "cos(60°) = 1/2. Запам'ятай таблицю значень: cos(0°)=1, cos(30°)=√3/2, cos(60°)=1/2, cos(90°)=0."),
            ("📝", "Українська", "badge-green",
             "Яке слово написане правильно?",
             "Твоя відповідь: \"ночю\"",
             "Правильна: \"ніччю\"",
             "Іменники жіночого роду в орудному відмінку: ніч → ніччю. Подвоєння приголосних перед -ю."),
            ("🏛", "Історія", "badge-amber",
             "Коли відбулася Переяславська рада?",
             "Твоя відповідь: 1648 рік",
             "Правильна: 1654 рік",
             "Переяславська рада — 8 (18) січня 1654 року. Хмельницьке повстання почалося у 1648 році — не плутай дати."),
            ("📐", "Математика", "badge-blue",
             "Яке значення tg(45°)?",
             "Твоя відповідь: 0",
             "Правильна: 1",
             "tg(45°) = sin(45°)/cos(45°) = (√2/2)/(√2/2) = 1. Тангенс 45° завжди дорівнює 1."),
        };
    }

    @foreach (var (icon, subj, badge, q, userAns, corrAns, explanation) in mistakes)
    {
        var id = Guid.NewGuid().ToString("N")[..6];
        <div class="mistake-card" id="mc@(id)">
            <div class="mistake-header">
                <div class="mistake-q">@q</div>
                <span class="badge-zno @badge mistake-subject">@icon @subj</span>
            </div>
            <div class="answer-row">
                <div class="ans-chip user-wrong"><i class="bi bi-x-circle"></i> @userAns</div>
                <div class="ans-chip true-answer"><i class="bi bi-check-circle"></i> @corrAns</div>
            </div>
            <div class="explanation-text" id="exp@(id)">
                <strong>💡 Пояснення:</strong> @explanation
            </div>
            <div class="mistake-footer">
                <button class="btn-explain" onclick="toggleExp('@id')">
                    <i class="bi bi-lightbulb"></i> Пояснення
                </button>
                <button class="btn-resolve" onclick="markResolved('@id')">
                    <i class="bi bi-check2"></i> Засвоїв
                </button>
                <button class="btn-explain" style="margin-left:auto" onclick="addToFav()">
                    <i class="bi bi-bookmark"></i> В обране
                </button>
            </div>
        </div>
    }

</div>
</div>

@section Scripts {
<script>
function toggleExp(id) {
    document.getElementById('exp'+id).classList.toggle('open');
}
function markResolved(id) {
    const card = document.getElementById('mc'+id);
    card.style.opacity = '0.4';
    card.style.pointerEvents = 'none';
    showToast('Питання відмічено як засвоєне ✓', 'success');
}
function addToFav() { showToast('Додано в обране!', 'success'); }
</script>
}
