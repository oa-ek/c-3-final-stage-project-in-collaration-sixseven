@using ZNOWay.Models
@{
    ViewData["Title"] = "Головна";
    ViewData["ActivePage"] = "Home";
    Layout = "_Layout";

    var totalTests = (int)(ViewBag.TotalTests ?? 0);
    var avgScore = (double)(ViewBag.AvgScore ?? 0.0);
    var bestScore = (double)(ViewBag.BestScore ?? 0.0);
    var subjects = (List<Subject>)(ViewBag.Subjects ?? new List<Subject>());
    var recent = (List<UserResult>)(ViewBag.RecentResults ?? new List<UserResult>());
}

<div class="container py-5">

    <!-- Привітання -->
    <div style="margin-bottom:40px">
        <h1 style="font-family:var(--font-display); font-size:1.6rem; font-weight:700; margin-bottom:6px">
            Вітаємо, <span style="color:var(--clr-accent)">@User.Identity!.Name?.Split('@')[0]</span> 👋
        </h1>
        <p style="color:var(--clr-muted)">Продовжуй готуватись до ЗНО/НМТ</p>
    </div>

    <!-- Статистика -->
    <div class="row g-3 mb-5">
        <div class="col-6 col-md-4">
            <div class="card-zno text-center">
                <div style="font-size:2rem; font-weight:700; color:var(--clr-accent)">@totalTests</div>
                <div style="color:var(--clr-muted); font-size:.85rem; margin-top:4px">
                    <i class="bi bi-journal-check"></i> Тестів пройдено
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card-zno text-center">
                <div style="font-size:2rem; font-weight:700; color:var(--clr-success)">@avgScore%</div>
                <div style="color:var(--clr-muted); font-size:.85rem; margin-top:4px">
                    <i class="bi bi-bar-chart"></i> Середній результат
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card-zno text-center">
                <div style="font-size:2rem; font-weight:700; color:var(--clr-accent2)">@bestScore%</div>
                <div style="color:var(--clr-muted); font-size:.85rem; margin-top:4px">
                    <i class="bi bi-trophy"></i> Найкращий результат
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- Предмети -->
        <div class="col-lg-8">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px">
                <h2 style="font-family:var(--font-display); font-size:1.1rem; font-weight:700">
                    Предмети
                </h2>
                <a asp-controller="Subjects" asp-action="Index"
                   style="color:var(--clr-accent); font-size:.85rem; text-decoration:none">
                    Всі предмети <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            @if (!subjects.Any())
            {
                <div class="card-zno text-center" style="padding:40px">
                    <i class="bi bi-book" style="font-size:2.5rem; color:var(--clr-muted)"></i>
                    <p style="color:var(--clr-muted); margin-top:12px">Предмети ще не додані</p>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var subject in subjects)
                    {
                        var testCount = subject.Tests?.Count ?? 0;
                        <div class="col-sm-6">
                            <a asp-controller="Tests" asp-action="Index"
                               asp-route-subjectId="@subject.Id"
                               style="display:block; text-decoration:none">
                                <div class="card-zno" style="cursor:pointer">
                                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px">
                                        <div style="width:40px; height:40px; border-radius:10px;
                                                     background:rgba(79,138,255,.15);
                                                     display:flex; align-items:center; justify-content:center">
                                            <i class="bi bi-book" style="color:var(--clr-accent)"></i>
                                        </div>
                                        <span class="badge-zno badge-blue">@testCount тестів</span>
                                    </div>
                                    <div style="font-weight:600; color:var(--clr-text)">@subject.Name</div>
                                    <div style="margin-top:10px">
                                        <a asp-controller="Tests" asp-action="Index"
                                           asp-route-subjectId="@subject.Id"
                                           style="color:var(--clr-accent); font-size:.82rem; text-decoration:none">
                                            Переглянути тести <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Останні результати -->
        <div class="col-lg-4">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px">
                <h2 style="font-family:var(--font-display); font-size:1.1rem; font-weight:700">
                    Останні результати
                </h2>
                <a asp-controller="UserResults" asp-action="Index"
                   style="color:var(--clr-accent); font-size:.85rem; text-decoration:none">
                    Всі <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            @if (!recent.Any())
            {
                <div class="card-zno text-center" style="padding:32px">
                    <i class="bi bi-bar-chart" style="font-size:2rem; color:var(--clr-muted)"></i>
                    <p style="color:var(--clr-muted); margin-top:10px; font-size:.875rem">
                        Ще немає результатів.<br />Пройди свій перший тест!
                    </p>
                    <a asp-controller="Tests" asp-action="Index"
                       class="btn-zno btn-primary-zno"
                       style="margin-top:14px; justify-content:center">
                        Обрати тест
                    </a>
                </div>
            }
            else
            {
                <div style="display:flex; flex-direction:column; gap:10px">
                    @foreach (var r in recent)
                    {
                        var pct = r.TotalQuestions > 0
                        ? Math.Round((double)r.Score / r.TotalQuestions * 100, 0)
                        : 0;
                        var color = pct >= 75 ? "var(--clr-success)"
                        : pct >= 50 ? "var(--clr-warn)"
                        : "#f87171";
                        <div class="card-zno" style="padding:14px 18px">
                            <div style="display:flex; align-items:center; justify-content:space-between">
                                <div style="font-size:.875rem; font-weight:600; color:var(--clr-text)">
                                    @(r.Test?.Name ?? "Тест")
                                </div>
                                <div style="font-weight:700; color:@color">@pct%</div>
                            </div>
                            <div style="margin-top:6px">
                                <div class="progress-zno">
                                    <div class="progress-zno-fill"
                                         style="width:@pct%; background:@color"></div>
                                </div>
                            </div>
                            <div style="margin-top:6px; font-size:.75rem; color:var(--clr-muted)">
                                @r.Score з @r.TotalQuestions правильних
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>